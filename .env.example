# SDLL Web Application - Environment Variables
# Copy this to .env and fill in your values

# =============================================================================
# LOCAL DEVELOPMENT
# =============================================================================

# Flask configuration
FLASK_CONFIG=development
SECRET_KEY=your-secret-key-here

# Local MySQL database
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your-password
MYSQL_DB=sdll

# Encryption key for PII (generate with: python -c "import secrets; print(secrets.token_hex(32))")
ENCRYPTION_KEY=your-encryption-key-here

# =============================================================================
# PRODUCTION (Railway)
# =============================================================================
# These are set automatically by Railway when you add a MySQL plugin.
# You only need to set SECRET_KEY and ENCRYPTION_KEY manually.

# FLASK_CONFIG=production
# MYSQL_URL=mysql://user:password@host:port/database  (auto-set by Railway)
# SECRET_KEY=generate-a-strong-secret-key
# ENCRYPTION_KEY=generate-a-strong-encryption-key
